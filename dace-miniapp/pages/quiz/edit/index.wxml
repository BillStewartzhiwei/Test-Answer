<view class="page">
  <view class="section">
    <view class="title">{{quiz.title}}</view>
    <view class="muted">MVP 仅支持单选、多选、判断</view>
  </view>
  <view wx:for="{{quiz.questions}}" wx:key="id" class="card">
    <view>{{index + 1}}. {{item.content}}</view>
    <view class="muted">{{item.type}} · {{item.score}}分</view>
  </view>
  <view class="actions">
    <van-button block bind:click="addQuestion">添加题目</van-button>
    <van-button type="primary" block bind:click="publish">发布</van-button>
  </view>
</view>
