<view class="page">
  <view class="section">
    <view class="title">{{quiz.title}}</view>
    <view class="muted">每套题只能提交一次</view>
  </view>
  <view wx:for="{{quiz.questions}}" wx:key="id" class="card">
    <view>{{index + 1}}. {{item.content}}</view>
    <view class="muted">{{item.score}}分</view>
  </view>
  <van-button type="primary" block bind:click="submit">提交</van-button>
</view>
