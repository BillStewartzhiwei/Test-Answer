page {
  background: #f6f7f9;
  color: #1f2937;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(31, 41, 55, 0.06);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.actions {
  display: grid;
  gap: 20rpx;
}
