<view class="page">
  <view class="hero">
    <view class="title">答题结果</view>
    <view class="subtitle">正确率 {{accuracyText}} · 用时 {{result.durationSeconds}} 秒 · 第 {{result.rank}} 名</view>
  </view>
  <view class="card">
    <view class="score">{{result.score}} / {{result.totalScore}}</view>
    <view class="muted">本次得分</view>
  </view>
  <view class="section-title">答题明细</view>
  <view wx:for="{{result.details}}" wx:key="questionId" class="card">
    <view class="row">
      <view class="name">{{index + 1}}. {{item.title}}</view>
      <view class="pill">{{item.correct ? '正确' : '错误'}}</view>
    </view>
    <view class="muted">得分 {{item.score}}</view>
    <view class="muted">你的答案：{{item.selectedOptionIds}}</view>
    <view class="muted">正确答案：{{item.correctOptionIds}}</view>
  </view>
</view>
