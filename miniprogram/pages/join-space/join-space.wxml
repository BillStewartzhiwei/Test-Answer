<view class="page">
  <view class="hero">
    <view class="title">加入空间</view>
    <view class="subtitle">输入创建者分享的 6 位邀请码。</view>
  </view>
  <view class="card">
    <input class="input" maxlength="6" placeholder="6位字母数字码" value="{{code}}" bindinput="onCode"/>
    <button class="btn" bindtap="join">加入空间</button>
  </view>
</view>
